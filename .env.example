APP_HOST=127.0.0.1
APP_PORT=1557
CORS_ALLOW_ORIGIN=*

# Single switch field: mock | glm | deepseek
MODEL_PROVIDER=mock

# Model names
MODEL_GLM=glm-5
MODEL_DEEPSEEK=deepseek-reasoner
MODEL_MOCK=mock-v1

# API keys
GLM_API_KEY=
DEEPSEEK_API_KEY=

# API endpoints
GLM_API_BASE=https://open.bigmodel.cn/api/coding/paas/v4
GLM_CHAT_PATH=/chat/completions
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_CHAT_PATH=/v1/chat/completions

PROMPT_DIR=src/prompt
GUEST_MODE=true
LOCAL_ONLY=true
MAX_FILE_SIZE_MB=10

PROMPT_HOT_RELOAD=true

KNOWLEDGE_DOC_DIR=storage/knowledge
LOG_FILE_PATH=logs/ariadne.log
LOG_LEVEL=INFO

LLM_TIMEOUT_SEC=240
LLM_MAX_RETRIES=2
LLM_RETRY_DELAY_SEC=1.2
CHUNK_MAX_CONCURRENCY=3
